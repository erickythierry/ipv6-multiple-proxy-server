# =============================================
# IPv6 Multiple Proxy Server - Configuração Local
# =============================================
# Copie este arquivo para /etc/ipv6-proxy/proxy.env
# e ajuste conforme sua necessidade.
# =============================================

# Credenciais (deixe vazio para proxies SEM autenticação)
PROXY_USER=
PROXY_PASS=

# Porta inicial (as demais são sequenciais)
START_PORT=30000

# Tipo de proxy: socks5 ou http
PROXY_TYPE=socks5

# Interface de rede (vazio = auto-detectar)
NET_INTERFACE=

# Regras de acesso (opcionais, formato 3proxy)
# Se ALLOWED_HOSTS for definido, apenas esses hosts são permitidos.
# Se DENIED_HOSTS for definido, esses são bloqueados e o resto é permitido.
ALLOWED_HOSTS=
DENIED_HOSTS=

# Caminho do binário e do config gerado (não precisa alterar)
PROXY_BIN=/usr/local/bin/3proxy
CONFIG_FILE=/etc/3proxy/3proxy.cfg

# UID/GID para drop de privilégios do 3proxy após bind (nobody/nogroup)
RUN_USER_UID=65534
RUN_USER_GID=65534
